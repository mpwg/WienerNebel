{
  "name": "@wiener-nebel/mobile",
  "private": true,
  "version": "0.1.0",
  "main": "./App.tsx",
  "scripts": {
    "android": "expo start --android",
    "build": "expo export --platform android --output-dir dist/android && expo export --platform ios --output-dir dist/ios",
    "check": "tsc --noEmit -p tsconfig.json",
    "ios": "expo start --ios",
    "start": "expo start"
  },
  "dependencies": {
    "@wiener-nebel/ui-tokens": "workspace:*",
    "expo": "~55.0.8",
    "react": "19.2.4",
    "react-native": "0.84.1"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "typescript": "^5.6.3"
  }
}
